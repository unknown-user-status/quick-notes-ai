# Copy this file to `.env.local` and fill in your real Appwrite values.
# Values prefixed NEXT_PUBLIC_ are inlined into the static build (safe for Appwrite client IDs).

NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=replace-with-your-project-id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=replace-with-your-database-id
NEXT_PUBLIC_APPWRITE_TODOS_COLLECTION_ID=replace-with-todos-collection-id
NEXT_PUBLIC_APPWRITE_WALL_COLLECTION_ID=replace-with-wall-collection-id
